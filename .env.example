# Geral
PHOTOS_PER_BOOK=2
RAW_DIR=photos_raw
GROUPED_DIR=photos_grouped
TZ=Europe/Lisbon

# -------- DB (SQLite local) --------
DB_URL=sqlite:///./blt.db

# -------- Visão local (Ollama - sem dependência de cloud) --------
OLLAMA_HOST=http://localhost:11434
OLLAMA_VISION_MODEL=gemma3:4b
OLLAMA_FILTER_MODEL=phi4-mini

# Redimensionamento de imagens antes de enviar ao modelo de visão
VISION_MAX_SIDE=1280
VISION_JPEG_QUALITY=85

# Preço fixo (sem negociação/transporte na descrição - Vinted trata do envio)
BOOK_PRICE_EUR=7
