# Geral
PHOTOS_PER_BOOK=2
RAW_DIR=photos_raw
GROUPED_DIR=photos_grouped
TZ=Europe/Lisbon

# -------- DB (SQLite local) --------
DB_URL=sqlite:///./blt.db

# -------- Visão local (Ollama - sem dependência de cloud) --------
OLLAMA_HOST=http://localhost:11434
OLLAMA_VISION_MODEL=gemma3:4b
OLLAMA_FILTER_MODEL=phi4-mini

# Redimensionamento de imagens antes de enviar ao modelo de visão
VISION_MAX_SIDE=1280
VISION_JPEG_QUALITY=85

# -------- Info fixa para a descrição (categoria/condição/idioma são sempre --------
# -------- os mesmos e escolhidos à mão no Vinted, não são geridos aqui)   --------
SELLER_LOCATION=
SELLER_SHIPPING=

# Preços (margem negoc.)
PRICE_MIN=10
PRICE_MARGIN_EUR=2

# -------- Consulta de ISBN (deterministica, sem LLM) --------
# Opcional - sem isto usa-se o tier anonimo da Google Books (quota diaria
# partilhada, facilmente esgotada). Cria uma key gratis em
# console.cloud.google.com (ativar "Books API" -> Credentials -> Create
# credentials -> API key).
GOOGLE_BOOKS_API_KEY=
